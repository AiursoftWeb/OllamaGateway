@using Aiursoft.OllamaGateway.Entities
@model Aiursoft.OllamaGateway.Models.OllamaProvidersViewModels.CreateViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Edit Ollama Provider"]</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 col-xl-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Provider Connection Settings"]</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@ViewData["Id"]" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">@Localizer["Provider Name"]</label>
                            <input asp-for="Name" class="form-control" placeholder="@Localizer["e.g. Local Server"]" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BaseUrl" class="form-label">@Localizer["Base URL"]</label>
                            <input asp-for="BaseUrl" class="form-control" id="baseUrl" placeholder="http://localhost:11434" />
                            <span asp-validation-for="BaseUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BearerToken" class="form-label">@Localizer["Bearer Token"]</label>
                            <input asp-for="BearerToken" class="form-control" id="bearerToken" type="password" placeholder="@Localizer["Optional API Key"]" />
                            <span asp-validation-for="BearerToken" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="KeepAlive" class="form-label">@Localizer["Keep Alive Policy"]</label>
                            <input asp-for="KeepAlive" class="form-control" placeholder="5m" />
                            <div class="form-text small">
                                @Localizer["Controls how long models stay in memory after a request. Ollama format (e.g., '5m', '1h', '24h'). Use '0' to unload immediately, or '-1' to keep forever."]
                            </div>
                            <span asp-validation-for="KeepAlive" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="button" class="btn btn-outline-info me-md-2" onclick="testConnection()">@Localizer["Test Connection"]</button>
                            <a asp-action="Index" class="btn btn-outline-secondary me-md-2">@Localizer["Back to List"]</a>
                            <button type="submit" class="btn btn-primary">@Localizer["Save Changes"]</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-12 col-xl-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Proactive Model Warmup"]</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">
                        @Localizer["Select physical models that should be proactively kept loaded in this provider's VRAM. The gateway will periodically ping these models to prevent them from being unloaded."]
                    </p>
                </div>
                <div class="table-responsive">
                    @Html.AntiForgeryToken()
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["Model"]</th>
                                <th style="width: 80px;">@Localizer["Keep"]</th>
                                <th style="width: 80px;">@Localizer["Embed"]</th>
                                <th>@Localizer["Advanced Warmup Options"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var physicalModels = (ViewData["PhysicalModels"] as IEnumerable<string>)?.ToList();
                                var warmupModels = ViewData["WarmupModels"] as List<WarmupModel> ?? new List<WarmupModel>();
                            }
                            @if (physicalModels == null || !physicalModels.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">@Localizer["No physical models found on this server."]</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var m in physicalModels)
                                {
                                    var warmupModel = warmupModels.FirstOrDefault(wm => wm.Name == m);
                                    var isEnabled = warmupModel != null;
                                    <tr data-model-name="@m">
                                        <td class="align-middle"><code>@m</code></td>
                                        <td class="align-middle">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox"
                                                       checked="@(isEnabled ? "checked" : null)" 
                                                       onchange="toggleWarmup(event, '@m')">
                                            </div>
                                        </td>
                                        <td class="align-middle">
                                            <div class="form-check form-switch embed-toggle @(isEnabled ? "" : "d-none")">
                                                <input class="form-check-input" type="checkbox" title="isEmbedding"
                                                       checked="@(warmupModel?.IsEmbedding == true ? "checked" : null)"
                                                       onchange="updateOptions(event, '@m')">
                                            </div>
                                        </td>
                                        <td>
                                            <div class="options-container @(isEnabled ? "" : "d-none") @(warmupModel?.IsEmbedding == true ? "d-none" : "")">
                                                <div class="row g-2">
                                                    <div class="col-md-6 col-lg-3">
                                                        <div class="input-group input-group-sm">
                                                            <span class="input-group-text">Ctx</span>
                                                            <input type="number" class="form-control" title="num_ctx" placeholder="4096" value="@warmupModel?.NumCtx" onchange="updateOptions(event, '@m')">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6 col-lg-3">
                                                        <div class="input-group input-group-sm">
                                                            <span class="input-group-text">Temp</span>
                                                            <input type="number" step="0.1" class="form-control" title="temperature" placeholder="0.8" value="@warmupModel?.Temperature" onchange="updateOptions(event, '@m')">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6 col-lg-3">
                                                        <div class="input-group input-group-sm">
                                                            <span class="input-group-text">Top P</span>
                                                            <input type="number" step="0.1" class="form-control" title="top_p" placeholder="0.9" value="@warmupModel?.TopP" onchange="updateOptions(event, '@m')">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6 col-lg-3">
                                                        <div class="input-group input-group-sm">
                                                            <span class="input-group-text">Top K</span>
                                                            <input type="number" class="form-control" title="top_k" placeholder="40" value="@warmupModel?.TopK" onchange="updateOptions(event, '@m')">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div id="testResult" class="col-md-4" style="display:none;">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">@Localizer["Connection Test"]</h5>
                </div>
                <div id="testContent" class="card-body">
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        async function testConnection() {
            const baseUrl = document.getElementById('baseUrl').value;
            const bearerToken = document.getElementById('bearerToken').value;
            const resultDiv = document.getElementById('testResult');
            const contentDiv = document.getElementById('testContent');
            
            resultDiv.style.display = 'block';
            contentDiv.innerHTML = '<div class="text-center"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Connecting...</div>';
            
            try {
                const response = await fetch('@Url.Action("Test")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ baseUrl, bearerToken })
                });
                const data = await response.json();
                
                if (data.success) {
                    contentDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="align-middle me-2" data-feather="check-circle"></i>Connected! Found ' + data.models.length + ' models.</div>';
                    if (window.feather) window.feather.replace();
                } else {
                    contentDiv.innerHTML = '<div class="alert alert-danger mb-0"><i class="align-middle me-2" data-feather="alert-triangle"></i>' + data.message + '</div>';
                    if (window.feather) window.feather.replace();
                }
            } catch (e) {
                contentDiv.innerHTML = '<div class="alert alert-danger mb-0">Error: ' + e.message + '</div>';
            }
        }

        async function toggleWarmup(event, modelName) {
            const isChecked = event.target.checked;
            const row = event.target.closest('tr');
            const optionsContainer = row.querySelector('.options-container');
            const embedToggle = row.querySelector('.embed-toggle');
            
            // UI optimistic update
            if (isChecked) {
                optionsContainer.classList.remove('d-none');
                embedToggle.classList.remove('d-none');
            } else {
                optionsContainer.classList.add('d-none');
                embedToggle.classList.add('d-none');
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const formData = new FormData();
            formData.append('modelName', modelName);
            
            try {
                const response = await fetch('@Url.Action("ToggleWarmup", new { id = ViewData["Id"] })', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    body: formData
                });
                
                if (!response.ok) {
                    alert('Failed to toggle warmup. Please try again.');
                    // Revert UI
                    event.target.checked = !isChecked;
                    if (!isChecked) { optionsContainer.classList.remove('d-none'); embedToggle.classList.remove('d-none'); }
                    else { optionsContainer.classList.add('d-none'); embedToggle.classList.add('d-none'); }
                }
            } catch (e) {
                console.error('Failed to toggle warmup:', e);
                alert('An error occurred. Please check console.');
                // Revert UI
                event.target.checked = !isChecked;
                if (!isChecked) { optionsContainer.classList.remove('d-none'); embedToggle.classList.remove('d-none'); }
                else { optionsContainer.classList.add('d-none'); embedToggle.classList.add('d-none'); }
            }
        }

        async function updateOptions(event, modelName) {
            const row = event.target.closest('tr');
            const inputs = row.querySelectorAll('.options-container input[type="number"]');
            const embedCheckbox = row.querySelector('.embed-toggle input[type="checkbox"]');
            const optionsContainer = row.querySelector('.options-container');
            const isEmbed = embedCheckbox ? embedCheckbox.checked : false;
            
            // Toggle visibility of chat options based on embedding state
            if (isEmbed) {
                optionsContainer.classList.add('d-none');
            } else {
                optionsContainer.classList.remove('d-none');
            }
            
            const nCtx = inputs[0]?.value;
            const temp = inputs[1]?.value;
            const tP = inputs[2]?.value;
            const tK = inputs[3]?.value;

            const formData = new FormData();
            formData.append('modelName', modelName);
            formData.append('isEmbedding', isEmbed);
            if (nCtx) formData.append('numCtx', nCtx);
            if (temp) formData.append('temperature', temp);
            if (tP) formData.append('topP', tP);
            if (tK) formData.append('topK', tK);
            
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            // Visual feedback
            event.target.classList.remove('is-valid', 'is-invalid');
            
            try {
                const response = await fetch('@Url.Action("UpdateWarmupOptions", new { id = ViewData["Id"] })', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    body: formData
                });
                
                if (response.ok) {
                    event.target.classList.add('is-valid');
                    setTimeout(() => event.target.classList.remove('is-valid'), 2000);
                } else {
                    event.target.classList.add('is-invalid');
                }
            } catch (e) {
                console.error('Failed to update options:', e);
                event.target.classList.add('is-invalid');
            }
        }
    </script>
}
