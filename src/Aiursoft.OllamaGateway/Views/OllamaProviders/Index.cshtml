@model Aiursoft.OllamaGateway.Models.OllamaProvidersViewModels.IndexViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Ollama Providers"]</h1>
        </div>
        <div class="col-auto ms-auto text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="align-middle me-1" data-lucide="plus"></i>
                @Localizer["Add New Provider"]
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Manage underlying Ollama servers"]</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Base URL"]</th>
                        <th>@Localizer["Version"]</th>
                        <th>@Localizer["Running Models"]</th>
                        <th>@Localizer["Created"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ProviderStatuses.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                @Localizer["No providers defined yet."]
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model.ProviderStatuses)
                        {
                            <tr>
                                <td>
                                    @if (p.IsAlive)
                                    {
                                        <span class="badge bg-success">@Localizer["Alive"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@Localizer["Offline"]</span>
                                    }
                                </td>
                                <td><strong>@p.Provider.Name</strong></td>
                                <td><code>@p.Provider.BaseUrl</code></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.Version))
                                    {
                                        <span class="badge bg-info">@p.Version</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Localizer["Unknown"]</span>
                                    }
                                </td>
                                <td>
                                    @if (p.IsAlive && p.RunningModels != null && p.RunningModels.Any())
                                    {
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var m in p.RunningModels)
                                            {
                                                <li>
                                                    <strong>@m.Name</strong>
                                                    <span class="badge bg-secondary ms-1">@(m.SizeVram > 0 ? "GPU" : "CPU")</span>
                                                    <span class="badge bg-info ms-1">@Localizer["Ctx"]: @(m.ContextLength ?? 0)</span>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else if (p.IsAlive)
                                    {
                                        <span class="text-muted">@Localizer["No models running"]</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Localizer["N/A"]</span>
                                    }
                                </td>
                                <td>@p.Provider.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@p.Provider.Id" class="btn btn-sm btn-outline-primary" title="@Localizer["Edit"]">
                                            <i class="align-middle" data-lucide="edit"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@p.Provider.Id" method="post" onsubmit="return confirm('@Localizer["Are you sure you want to delete this provider? All linked virtual models will also be deleted."]');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="align-middle" data-lucide="trash-2"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
