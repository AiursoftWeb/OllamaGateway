@model Aiursoft.OllamaGateway.Models.OllamaProvidersViewModels.CreateViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Add New Ollama Provider"]</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-5">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Provider Details"]</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" id="create-provider-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">@Localizer["Provider Name"]</label>
                            <input asp-for="Name" class="form-control" placeholder="@Localizer["e.g. My Local Ollama"]" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="BaseUrl" class="form-label">@Localizer["Base URL"]</label>
                            <div class="input-group">
                                <input asp-for="BaseUrl" id="baseUrlInput" class="form-control" placeholder="http://localhost:11434" />
                                <button class="btn btn-outline-secondary" type="button" id="btnTestConnection">
                                    <span id="testSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                    <span id="testText">@Localizer["Test Connection"]</span>
                                </button>
                            </div>
                            <span asp-validation-for="BaseUrl" class="text-danger"></span>
                            <div class="form-text">@Localizer["The URL where Ollama is listening."]</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BearerToken" class="form-label">@Localizer["Bearer Token (Optional)"]</label>
                            <input asp-for="BearerToken" id="bearerTokenInput" class="form-control" placeholder="e.g. sk-..." />
                            <span asp-validation-for="BearerToken" class="text-danger"></span>
                            <div class="form-text">@Localizer["The Bearer Token for authorization if required by the upstream server."]</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="KeepAlive" class="form-label">@Localizer["Keep Alive Policy"]</label>
                            <input asp-for="KeepAlive" class="form-control" placeholder="5m" />
                            <div class="form-text small">
                                @Localizer["Controls how long models stay in memory after a request. Ollama format (e.g., '5m', '1h', '24h'). Use '0' to unload immediately, or '-1' to keep forever."]
                            </div>
                            <span asp-validation-for="KeepAlive" class="text-danger"></span>
                        </div>

                        <div id="testResult" class="alert d-none mb-3"></div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary" id="btnSubmit">@Localizer["Add Provider"]</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="loc-data" hidden>
    <span data-key="please-enter-url">@Localizer["Please enter a URL first."]</span>
    <span data-key="testing">@Localizer["Testing..."]</span>
    <span data-key="success">@Localizer["Success!"]</span>
    <span data-key="successfully-connected">@Localizer["Successfully connected to Ollama."]</span>
    <span data-key="models-found">@Localizer["Models found:"]</span>
    <span data-key="network-error">@Localizer["Network error or invalid request."]</span>
    <span data-key="test-connection">@Localizer["Test Connection"]</span>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        function getLocalizedText(key, defaultText) {
            const el = document.querySelector(`#loc-data span[data-key="${key}"]`);
            return el ? el.innerText : defaultText;
        }

        document.getElementById('btnTestConnection').addEventListener('click', async function() {
            const baseUrl = document.getElementById('baseUrlInput').value;
            const bearerToken = document.getElementById('bearerTokenInput').value;
            const btn = this;
            const spinner = document.getElementById('testSpinner');
            const text = document.getElementById('testText');
            const resultDiv = document.getElementById('testResult');
            const submitBtn = document.getElementById('btnSubmit');

            if (!baseUrl) {
                alert(getLocalizedText('please-enter-url', 'Please enter a URL first.'));
                return;
            }

            // UI Loading state
            btn.disabled = true;
            spinner.classList.remove('d-none');
            text.innerText = getLocalizedText('testing', 'Testing...');
            resultDiv.classList.add('d-none');
            resultDiv.classList.remove('alert-success', 'alert-danger');

            try {
                const response = await fetch('@Url.Action("Test")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        baseUrl: baseUrl,
                        bearerToken: bearerToken
                    })
                });

                const data = await response.json();

                resultDiv.classList.remove('d-none');
                if (data.success) {
                    resultDiv.classList.add('alert-success');
                    let modelsText = data.models.length > 0 ? data.models.join(', ') : 'None';
                    resultDiv.innerHTML = `<strong>${getLocalizedText('success', 'Success!')}</strong> ${getLocalizedText('successfully-connected', 'Successfully connected to Ollama.')} <br/> <strong>${getLocalizedText('models-found', 'Models found:')}</strong> ${modelsText}`;
                    submitBtn.disabled = false;
                } else {
                    resultDiv.classList.add('alert-danger');
                    resultDiv.innerText = data.message;
                }
            } catch (error) {
                resultDiv.classList.remove('d-none');
                resultDiv.classList.add('alert-danger');
                resultDiv.innerText = getLocalizedText('network-error', 'Network error or invalid request.');
            } finally {
                btn.disabled = false;
                spinner.classList.add('d-none');
                text.innerText = getLocalizedText('test-connection', 'Test Connection');
            }
        });
    </script>
}
