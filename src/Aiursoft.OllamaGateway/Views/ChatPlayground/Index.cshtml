@inject IViewLocalizer Localizer
@model Aiursoft.OllamaGateway.Models.ChatPlaygroundViewModels.IndexViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Chat Playground"]</h1>
        </div>
        <div class="col-auto ms-auto d-flex align-items-center">
            <label class="me-2 fw-bold">@Localizer["API Mode:"]</label>
            <select class="form-select form-select-sm me-3" id="apiMode" style="width: auto;">
                <option value="ollama">Ollama API</option>
                <option value="openai">OpenAI API</option>
            </select>

            <label class="me-2 fw-bold">@Localizer["Switch Model:"]</label>
            <select class="form-select form-select-sm" style="width: auto;" onchange="window.location.href='?id=' + this.value">
                @foreach (var m in Model.AllModels)
                {
                    <option value="@m.Id" selected="@(m.Id == Model.ModelId ? "selected" : null)">@m.Name</option>
                }
            </select>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header cursor-pointer" data-bs-toggle="collapse" data-bs-target="#advancedOptions">
            <div class="d-flex align-items-center">
                <i class="me-2" data-lucide="settings" style="width: 18px; height: 18px;"></i>
                <h5 class="card-title mb-0">@Localizer["Advanced Options"]</h5>
                <i class="ms-auto" data-lucide="chevron-down" style="width: 18px; height: 18px;"></i>
            </div>
        </div>
        <div id="advancedOptions" class="collapse">
            <div class="card-body pt-0">
                <hr class="mt-0">
                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label class="form-label small fw-bold">@Localizer["Temperature"]</label>
                        <input type="number" step="0.1" class="form-control form-control-sm" id="temperature" placeholder="Default" value="@Model.Temperature">
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label small fw-bold">@Localizer["Top P"]</label>
                        <input type="number" step="0.1" class="form-control form-control-sm" id="topP" placeholder="Default" value="@Model.TopP">
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label small fw-bold">@Localizer["Top K"]</label>
                        <input type="number" class="form-control form-control-sm" id="topK" placeholder="Default" value="@Model.TopK">
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label small fw-bold">@Localizer["Num Ctx"]</label>
                        <input type="number" class="form-control form-control-sm" id="numCtx" placeholder="Default" value="@Model.NumCtx">
                    </div>
                    <div class="col-md-2 mb-3">
                        <div class="form-check form-switch mt-4">
                            <input class="form-check-input" type="checkbox" id="thinking" @(Model.Thinking == true ? "checked" : "")>
                            <label class="form-check-label small fw-bold" for="thinking">@Localizer["Thinking"]</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card flex-fill w-100" style="min-height: calc(100vh - 350px);">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="card-title mb-0">@Localizer["Chatting with"] <strong>@Model.Name</strong></h5>
                <small class="text-muted d-block">@Localizer["Provider Model:"] @Model.UnderlyingModel</small>
                <small class="text-muted d-block mt-1">
                    @Localizer["API Endpoint:"] <code id="endpointDisplay">@Model.BaseUrl/api/chat</code>
                </small>
            </div>
            <button class="btn btn-sm btn-outline-secondary" id="btnClearChat">@Localizer["Clear Session"]</button>
        </div>
        <div class="card-body d-flex flex-column p-0">
            <div id="chatMessages" class="flex-grow-1 overflow-auto p-3" style="background-color: #f8f9fa;">
                <div class="text-center text-muted my-5" id="welcomeMessage">
                    <i class="align-middle me-2" data-lucide="sparkles" style="width: 48px; height: 48px; color: #ffc107;"></i>
                    <p class="mt-2">@Localizer["Hello! Send a message to start testing your virtual model configuration."]</p>
                </div>
            </div>
            
            <div class="p-3 border-top bg-white">
                <div id="imagePreviewContainer" class="mb-2 d-none"></div>
                <form id="chatForm" class="input-group">
                    <button class="btn btn-outline-secondary" type="button" id="btnUploadImage">
                        <i class="align-middle" data-lucide="plus"></i>
                    </button>
                    <input type="file" id="imageInput" accept="image/*" class="d-none">
                    <input type="text" id="userInput" class="form-control" placeholder="@Localizer["Ask anything..."]" autocomplete="off" required>
                    <button class="btn btn-primary" type="submit" id="btnSend">
                        <i class="align-middle" data-lucide="send"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .message {
        margin-bottom: 1rem;
        max-width: 85%;
        padding: 0.75rem 1rem;
        border-radius: 1rem;
        position: relative;
        word-wrap: break-word;
    }
    .message-user {
        background-color: #3b7ddd;
        color: white;
        align-self: flex-end;
        margin-left: auto;
        border-bottom-right-radius: 0.25rem;
    }
    .message-assistant {
        background-color: #ffffff;
        color: #212529;
        align-self: flex-start;
        border-bottom-left-radius: 0.25rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    #chatMessages {
        display: flex;
        flex-direction: column;
    }
    .thinking-container {
        border-left: 3px solid #dee2e6;
        background-color: #fdfdfd;
        margin-bottom: 0.5rem;
    }
    .thinking-header {
        cursor: pointer;
        padding: 4px 8px;
        user-select: none;
        transition: background-color 0.2s;
    }
    .thinking-header:hover {
        background-color: #f1f3f5;
    }
    .thinking-content {
        max-height: 300px;
        overflow-y: auto;
    }
    .cursor-pointer {
        cursor: pointer;
    }
</style>

<div id="loc-data" hidden>
    <span data-key="session-cleared">@Localizer["Session cleared. Send a new message to start over."]</span>
    <span data-key="error-prefix">@Localizer["Error: "]</span>
    <span data-key="thinking">@Localizer["Thinking..."]</span>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        function getLocalizedText(key, defaultText) {
            const el = document.querySelector(`#loc-data span[data-key="${key}"]`);
            return el ? el.innerText : defaultText;
        }

        const chatMessages = document.getElementById('chatMessages');
        const chatForm = document.getElementById('chatForm');
        const userInput = document.getElementById('userInput');
        const btnSend = document.getElementById('btnSend');
        const btnClearChat = document.getElementById('btnClearChat');
        const btnUploadImage = document.getElementById('btnUploadImage');
        const imageInput = document.getElementById('imageInput');
        const imagePreviewContainer = document.getElementById('imagePreviewContainer');
        const apiModeSelect = document.getElementById('apiMode');
        const endpointDisplay = document.getElementById('endpointDisplay');
        
        let history = [];
        let pendingImages = [];

        apiModeSelect.addEventListener('change', () => {
            if (apiModeSelect.value === 'ollama') {
                endpointDisplay.innerText = '@Model.BaseUrl/api/chat';
            } else {
                endpointDisplay.innerText = '@Model.BaseUrl/v1/chat/completions';
            }
        });

        function appendMessage(role, content, images = []) {
            const welcome = document.getElementById('welcomeMessage');
            if (welcome) welcome.remove();

            const msgDiv = document.createElement('div');
            msgDiv.className = `message message-${role}`;
            
            if (role === 'assistant') {
                // Prepare thinking container
                const thinkContainer = document.createElement('div');
                thinkContainer.className = 'thinking-container mb-2 d-none';
                thinkContainer.innerHTML = `
                    <div class="thinking-header d-flex align-items-center">
                        <i class="align-middle me-1" style="width: 14px; height: 14px;" data-lucide="brain"></i>
                        <small class="fw-bold">${getLocalizedText('thinking', 'Thinking...')}</small>
                        <div class="spinner-border spinner-border-sm ms-2 thinking-spinner" role="status"></div>
                        <i class="align-middle ms-auto toggle-icon" style="width: 14px; height: 14px;" data-lucide="chevron-down"></i>
                    </div>
                    <div class="thinking-content mt-1 p-2 bg-light border rounded small d-none" style="white-space: pre-wrap;"></div>
                `;
                msgDiv.appendChild(thinkContainer);
                
                const contentDiv = document.createElement('div');
                contentDiv.className = 'message-content';
                contentDiv.innerText = content;
                msgDiv.appendChild(contentDiv);
                
                // Toggle logic
                const header = thinkContainer.querySelector('.thinking-header');
                const thinkContent = thinkContainer.querySelector('.thinking-content');
                const toggleIcon = thinkContainer.querySelector('.toggle-icon');
                header.onclick = () => {
                    thinkContent.classList.toggle('d-none');
                    toggleIcon.style.transform = thinkContent.classList.contains('d-none') ? '' : 'rotate(180deg)';
                };
                
                if (typeof lucide !== 'undefined') {
                    lucide.createIcons({
                        attrs: {
                            class: 'align-middle'
                        },
                        nameAttr: 'data-lucide',
                        icons: undefined
                    });
                }
            } else {
                msgDiv.innerText = content;
            }

            if (images && images.length > 0) {
                const imgContainer = document.createElement('div');
                imgContainer.className = 'mt-2';
                images.forEach(imgBase64 => {
                    const img = document.createElement('img');
                    img.src = `data:image/jpeg;base64,${imgBase64}`;
                    img.className = 'img-thumbnail me-2 mb-2';
                    img.style.maxHeight = '150px';
                    imgContainer.appendChild(img);
                });
                msgDiv.appendChild(imgContainer);
            }

            chatMessages.appendChild(msgDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            return msgDiv;
        }

        function renderPreviews() {
            imagePreviewContainer.innerHTML = '';
            if (pendingImages.length > 0) {
                imagePreviewContainer.classList.remove('d-none');
                pendingImages.forEach((imgBase64, index) => {
                    const wrapper = document.createElement('div');
                    wrapper.className = 'position-relative d-inline-block me-2 mb-2';
                    
                    const img = document.createElement('img');
                    img.src = `data:image/jpeg;base64,${imgBase64}`;
                    img.className = 'img-thumbnail';
                    img.style.maxHeight = '100px';
                    
                    const removeBtn = document.createElement('button');
                    removeBtn.className = 'btn btn-sm btn-danger position-absolute p-0 d-flex align-items-center justify-content-center';
                    removeBtn.style.top = '-5px';
                    removeBtn.style.right = '-5px';
                    removeBtn.style.width = '20px';
                    removeBtn.style.height = '20px';
                    removeBtn.style.borderRadius = '50%';
                    removeBtn.innerHTML = '&times;';
                    removeBtn.type = 'button';
                    removeBtn.onclick = () => {
                        pendingImages.splice(index, 1);
                        renderPreviews();
                        updateRequired();
                    };
                    
                    wrapper.appendChild(img);
                    wrapper.appendChild(removeBtn);
                    imagePreviewContainer.appendChild(wrapper);
                });
            } else {
                imagePreviewContainer.classList.add('d-none');
            }
        }

        function addImageToPreview(base64Str) {
            pendingImages.push(base64Str);
            renderPreviews();
            updateRequired();
        }

        function updateRequired() {
            if (pendingImages.length > 0) {
                userInput.removeAttribute('required');
            } else {
                userInput.setAttribute('required', 'required');
            }
        }

        function processFile(file) {
            if (!file || !file.type.startsWith('image/')) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                const base64 = e.target.result.split(',')[1];
                addImageToPreview(base64);
            };
            reader.readAsDataURL(file);
        }

        btnUploadImage.addEventListener('click', () => {
            imageInput.click();
        });

        imageInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                processFile(e.target.files[0]);
                e.target.value = ''; 
            }
        });

        userInput.addEventListener('paste', (e) => {
            const items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (let index in items) {
                const item = items[index];
                if (item.kind === 'file' && item.type.startsWith('image/')) {
                    const file = item.getAsFile();
                    processFile(file);
                }
            }
        });

        btnClearChat.addEventListener('click', () => {
            chatMessages.innerHTML = `
                <div class="text-center text-muted my-5" id="welcomeMessage">
                    <i class="align-middle me-2" data-lucide="sparkles" style="width: 48px; height: 48px; color: #ffc107;"></i>
                    <p class="mt-2">${getLocalizedText('session-cleared', 'Session cleared. Send a new message to start over.')}</p>
                </div>`;
            history = [];
            pendingImages = [];
            renderPreviews();
            updateRequired();
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });

        chatForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const message = userInput.value.trim();
            if (!message && pendingImages.length === 0) return;

            userInput.value = '';
            userInput.disabled = true;
            btnSend.disabled = true;
            btnUploadImage.disabled = true;

            const imagesToSend = [...pendingImages];
            pendingImages = [];
            renderPreviews();
            updateRequired();

            appendMessage('user', message, imagesToSend);
            
            const msgObj = { role: 'user', content: message };
            if (imagesToSend.length > 0) {
                msgObj.images = imagesToSend;
            }
            history.push(msgObj);

            const assistantMsgDiv = appendMessage('assistant', '...');
            const contentDiv = assistantMsgDiv.querySelector('.message-content');
            const thinkContainer = assistantMsgDiv.querySelector('.thinking-container');
            const thinkContent = assistantMsgDiv.querySelector('.thinking-content');
            const thinkSpinner = assistantMsgDiv.querySelector('.thinking-spinner');
            
            let assistantFullContent = '';
            let assistantFullThinking = '';
            const mode = apiModeSelect.value;

            try {
                const endpoint = mode === 'ollama' ? '/api/chat' : '/v1/chat/completions';
                
                const temperature = parseFloat(document.getElementById('temperature').value);
                const topP = parseFloat(document.getElementById('topP').value);
                const topK = parseInt(document.getElementById('topK').value);
                const numCtx = parseInt(document.getElementById('numCtx').value);
                const thinking = document.getElementById('thinking').checked;

                const options = {};
                if (!isNaN(temperature)) options.temperature = temperature;
                if (!isNaN(topP)) options.top_p = topP;
                if (!isNaN(topK)) options.top_k = topK;
                if (!isNaN(numCtx)) options.num_ctx = numCtx;

                const body = mode === 'ollama' ? {
                    model: '@Model.Name',
                    messages: history,
                    stream: true,
                    options: options,
                    think: thinking
                } : {
                    model: '@Model.Name',
                    messages: history.map(m => ({
                        role: m.role,
                        content: m.content
                    })),
                    stream: true,
                    temperature: isNaN(temperature) ? undefined : temperature,
                    top_p: isNaN(topP) ? undefined : topP,
                    max_tokens: isNaN(numCtx) ? undefined : numCtx
                };

                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });

                if (!response.ok) throw new Error(await response.text());

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                contentDiv.innerText = '';
                let lineBuffer = '';

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    lineBuffer += decoder.decode(value, { stream: true });
                    
                    if (mode === 'ollama') {
                        const lines = lineBuffer.split('\n');
                        lineBuffer = lines.pop() || '';
                        for (const line of lines) {
                            if (!line.trim()) continue;
                            try {
                                const data = JSON.parse(line);
                                if (data.message) {
                                    if (data.message.content) {
                                        assistantFullContent += data.message.content;
                                        contentDiv.innerText = assistantFullContent;
                                    }
                                    const thinkingContent = data.message.thinking || data.message.think;
                                    if (thinkingContent) {
                                        assistantFullThinking += thinkingContent;
                                        thinkContent.innerText = assistantFullThinking;
                                        thinkContainer.classList.remove('d-none');
                                    }
                                    if (data.done) {
                                        thinkSpinner.classList.add('d-none');
                                    }
                                }
                            } catch (e) { console.error(e); }
                        }
                    } else {
                        // OpenAI SSE
                        const lines = lineBuffer.split('\n');
                        lineBuffer = lines.pop() || '';
                        for (const line of lines) {
                            if (!line.startsWith('data: ')) continue;
                            const dataStr = line.substring(6).trim();
                            if (dataStr === '[DONE]') {
                                thinkSpinner.classList.add('d-none');
                                continue;
                            }
                            try {
                                const data = JSON.parse(dataStr);
                                const delta = data.choices[0].delta;
                                if (delta.content) {
                                    assistantFullContent += delta.content;
                                    contentDiv.innerText = assistantFullContent;
                                }
                                if (delta.reasoning_content) {
                                    assistantFullThinking += delta.reasoning_content;
                                    thinkContent.innerText = assistantFullThinking;
                                    thinkContainer.classList.remove('d-none');
                                }
                            } catch (e) { console.error(e); }
                        }
                    }
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
                
                history.push({ role: 'assistant', content: assistantFullContent });

            } catch (error) {
                contentDiv.classList.add('text-danger');
                contentDiv.innerText = getLocalizedText('error-prefix', 'Error: ') + error.message;
            } finally {
                thinkSpinner.classList.add('d-none');
                userInput.disabled = false;
                btnSend.disabled = false;
                btnUploadImage.disabled = false;
                userInput.focus();
            }
        });
    </script>
}
