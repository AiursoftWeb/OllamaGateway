@using Aiursoft.OllamaGateway.Entities
@model Aiursoft.OllamaGateway.Models.VirtualModelsViewModels.CreateViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Edit Virtual Model"]</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Virtual Model Configuration"]</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@ViewData["Id"]" method="post">
                        <input type="hidden" asp-for="Type" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label">@Localizer["Virtual Model Name"]</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SelectionStrategy" class="form-label">@Localizer["Selection Strategy"]</label>
                                <select asp-for="SelectionStrategy" class="form-select" asp-items="Html.GetEnumSelectList<SelectionStrategy>()"></select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaxRetries" class="form-label">@Localizer["Max Retries"]</label>
                                <input asp-for="MaxRetries" class="form-control" type="number" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="HealthCheckTimeout" class="form-label">@Localizer["Try Timeout (s)"]</label>
                                <input asp-for="HealthCheckTimeout" class="form-control" type="number" />
                            </div>
                        </div>

                        <hr />
                        <h6 class="card-subtitle mb-2 text-muted">@Localizer["Optional Model Overrides"]</h6>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Thinking" class="form-label">@Localizer["Thinking Mode"]</label>
                                <select asp-for="Thinking" class="form-select" asp-items="@(ViewData["ThinkingOptions"] as IEnumerable<SelectListItem>)"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Temperature" class="form-label">@Localizer["Temperature"]</label>
                                <input asp-for="Temperature" class="form-control" type="number" step="0.1" min="0" max="2" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="NumCtx" class="form-label">@Localizer["Ollama num_ctx Override"]</label>
                                <input asp-for="NumCtx" class="form-control" type="number" />
                                <div class="form-text small">@Localizer["Upstream window size."]</div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="TopP" class="form-label">@Localizer["Top P"]</label>
                                <input asp-for="TopP" class="form-control" type="number" step="0.1" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="TopK" class="form-label">@Localizer["Top K"]</label>
                                <input asp-for="TopK" class="form-control" type="number" />
                            </div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="UseRawOutput" class="form-check-input" type="checkbox" />
                            <label asp-for="UseRawOutput" class="form-check-label">@Localizer["Use Raw Output"]</label>
                            <div class="form-text small">@Localizer["When checked, the 'raw: true' parameter is sent to the upstream Ollama API. This tells Ollama to NOT apply any chat templates to your prompt. Use this for pure text completion. If unchecked, Ollama will automatically wrap your prompt in the model's default chat template, treating it as a conversational question."]</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary me-md-2">@Localizer["Back to List"]</a>
                            <button type="submit" class="btn btn-primary">@Localizer["Save Configuration"]</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-12 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Model Backends (1:N Support)"]</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["Provider"]</th>
                                <th>@Localizer["Underlying"]</th>
                                <th>@Localizer["Priority"]</th>
                                <th>@Localizer["Weight"]</th>
                                <th>@Localizer["Status"]</th>
                                <th>@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var backends = (ViewData["Backends"] as IEnumerable<VirtualModelBackend>)?.ToList();
                            }
                            @if (backends == null || !backends.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">@Localizer["No backends added."]</td></tr>
                            }
                            else
                            {
                                @foreach (var b in backends)
                                {
                                    <tr class="@(b.Enabled ? "" : "opacity-50")">
                                        <form asp-action="UpdateBackend" asp-route-id="@b.Id" method="post">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="form-check form-switch me-2">
                                                        <input class="form-check-input" type="checkbox" checked="@(b.Enabled ? "checked" : null)" 
                                                               onclick="if(confirm('@Localizer["Toggle this backend?"]')) { document.getElementById('toggle-form-@b.Id').submit(); } else { return false; }">
                                                    </div>
                                                    @b.Provider?.Name
                                                </div>
                                            </td>
                                            <td><code>@b.UnderlyingModelName</code></td>
                                            <td>
                                                <input type="number" name="priority" value="@b.Priority" class="form-control form-control-sm" style="width: 70px;" />
                                            </td>
                                            <td>
                                                <input type="number" name="weight" value="@b.Weight" class="form-control form-control-sm" style="width: 70px;" />
                                            </td>
                                            <td>
                                                @{
                                                    var banTime = Model.BackendBanStatuses.GetValueOrDefault(b.Id);
                                                }
                                                @if (!b.Enabled) { <span class="badge bg-secondary">Disabled</span> }
                                                else if (banTime.HasValue && banTime.Value > DateTime.UtcNow) { <span class="badge bg-danger">Banned (Till @banTime.Value.ToLocalTime().ToString("HH:mm"))</span> }
                                                else if (b.IsReady) { <span class="badge bg-success">Ready</span> }
                                                else if (b.IsHealthy) { <span class="badge bg-info">Healthy</span> }
                                                else { <span class="badge bg-danger">Down</span> }
                                            </td>
                                            <td>
                                                <div class="btn-group">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="@Localizer["Save Changes"]">
                                                        <i data-lucide="save" style="width:14px;"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </form>
                                        <form id="toggle-form-@b.Id" asp-action="ToggleBackend" asp-route-id="@b.Id" method="post" style="display:none;"></form>
                                        <td>
                                            <form asp-action="DeleteBackend" asp-route-id="@b.Id" method="post" onsubmit="return confirm('@Localizer["Are you sure?"]');" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="@Localizer["Delete"]">
                                                    <i data-lucide="trash-2" style="width:14px;"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer">
                    <h6>@Localizer["Add New Backend"]</h6>
                    <form asp-action="AddBackend" asp-route-id="@ViewData["Id"]" method="post" class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small mb-1">@Localizer["Provider"]</label>
                            <select name="providerId" class="form-select form-select-sm" onchange="window.location.href='?id=@ViewData["Id"]&amp;providerId=' + this.value">
                                <option value="">@Localizer["-- Select Provider --"]</option>
                                @foreach (var p in Model.AvailableProviders)
                                {
                                    <option value="@p.Id" selected="@(p.Id == Model.ProviderId ? "selected" : null)">@p.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">@Localizer["Underlying Model"]</label>
                            <select name="underlyingModel" class="form-select form-select-sm">
                                <option value="">@Localizer["-- Select Model --"]</option>
                                @foreach (var m in Model.AvailableUnderlyingModels)
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">@Localizer["Priority"]</label>
                            <input type="number" name="priority" class="form-control form-control-sm" placeholder="@Localizer["Priority"]" value="1" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">@Localizer["Weight"]</label>
                            <input type="number" name="weight" class="form-control form-control-sm" placeholder="@Localizer["Weight"]" value="1" />
                        </div>
                        <div class="col-md-6 text-end d-flex align-items-end">
                            <button type="submit" class="btn btn-sm btn-success w-100">@Localizer["Add Backend"]</button>
                        </div>
                    </form>
                    <div class="mt-3 p-2 bg-light rounded border">
                        <h6 class="small fw-bold mb-1">@Localizer["Configuration Guide:"]</h6>
                        <ul class="small text-muted mb-0 ps-3">
                            <li><strong>@Localizer["Priority"]</strong>: @Localizer["Used in 'Priority Fallback' strategy. Lower numbers (e.g. 0, 1) have higher priority. The system will always try the healthy backend with the lowest priority number first."]</li>
                            <li><strong>@Localizer["Weight"]</strong>: @Localizer["Used in 'Weighted Random' strategy. Higher numbers increase the traffic proportion. For example, a backend with weight 10 gets twice as much traffic as one with weight 5."]</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
