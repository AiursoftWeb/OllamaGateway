@using Aiursoft.OllamaGateway.Entities
@model Aiursoft.OllamaGateway.Models.VirtualModelsViewModels.CreateViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Create Virtual Model"] (@Model.Type)</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Basic Settings"]</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="Type" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label">@Localizer["Virtual Model Name"]</label>
                                <input asp-for="Name" class="form-control" placeholder="@Localizer["e.g. MyLlama3:latest"]" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SelectionStrategy" class="form-label">@Localizer["Selection Strategy"]</label>
                                <select asp-for="SelectionStrategy" class="form-select" asp-items="Html.GetEnumSelectList<SelectionStrategy>()"></select>
                                <span asp-validation-for="SelectionStrategy" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="MaxRetries" class="form-label">@Localizer["Max Retries"]</label>
                                <input asp-for="MaxRetries" class="form-control" type="number" />
                                <span asp-validation-for="MaxRetries" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="HealthCheckTimeout" class="form-label">@Localizer["Try Timeout (s)"]</label>
                                <input asp-for="HealthCheckTimeout" class="form-control" type="number" />
                                <span asp-validation-for="HealthCheckTimeout" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />
                        <h5 class="card-title mb-3">@Localizer["Initial Backend Configuration"]</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProviderId" class="form-label">@Localizer["Provider"]</label>
                                <select asp-for="ProviderId" class="form-select" onchange="window.location.href='?type=@Model.Type&amp;providerId=' + this.value">
                                    @foreach (var p in Model.AvailableProviders)
                                    {
                                        <option value="@p.Id" selected="@(p.Id == Model.ProviderId ? "selected" : null)">@p.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="ProviderId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="UnderlyingModel" class="form-label">@Localizer["Underlying Model"]</label>
                                <select asp-for="UnderlyingModel" class="form-select">
                                    <option value="">@Localizer["-- Select Underlying Model --"]</option>
                                    @foreach (var m in Model.AvailableUnderlyingModels)
                                    {
                                        <option value="@m">@m</option>
                                    }
                                </select>
                                <span asp-validation-for="UnderlyingModel" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />
                        <h6 class="card-subtitle mb-2 text-muted">@Localizer["Optional Model Overrides"]</h6>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Thinking" class="form-label">@Localizer["Thinking Mode"]</label>
                                <select asp-for="Thinking" class="form-select" asp-items="@(ViewData["ThinkingOptions"] as IEnumerable<SelectListItem>)"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Temperature" class="form-label">@Localizer["Temperature"]</label>
                                <input asp-for="Temperature" class="form-control" type="number" step="0.1" min="0" max="2" placeholder="0.7" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NumCtx" class="form-label">@Localizer["Ollama num_ctx Override"]</label>
                                <input asp-for="NumCtx" class="form-control" type="number" placeholder="32768" />
                                <div class="form-text small">@Localizer["Forces the upstream engine to allocate a specific window size."]</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TopP" class="form-label">@Localizer["Top P"]</label>
                                <input asp-for="TopP" class="form-control" type="number" step="0.1" placeholder="0.9" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TopK" class="form-label">@Localizer["Top K"]</label>
                                <input asp-for="TopK" class="form-control" type="number" placeholder="40" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="RepeatPenalty" class="form-label">@Localizer["Repeat Penalty"]</label>
                                <input asp-for="RepeatPenalty" class="form-control" type="number" step="0.1" placeholder="1.1" />
                            </div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="UseRawOutput" class="form-check-input" type="checkbox" />
                            <label asp-for="UseRawOutput" class="form-check-label">@Localizer["Use Raw Output"]</label>
                            <div class="form-text small">@Localizer["When checked, the 'raw: true' parameter is sent to the upstream Ollama API. This tells Ollama to NOT apply any chat templates to your prompt. Use this for pure text completion. If unchecked, Ollama will automatically wrap your prompt in the model's default chat template, treating it as a conversational question."]</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary me-md-2">@Localizer["Back to List"]</a>
                            <button type="submit" class="btn btn-primary">@Localizer["Create Virtual Model"]</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
