@using Aiursoft.OllamaGateway.Views.Shared.Components.RecentRequests
@using Aiursoft.WebTools
@model RecentRequestsViewModel

<div class="card flex-fill w-100">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 flex-grow-1">
            <i class="align-middle me-1" data-lucide="clock"></i>
            @Localizer["Recent Requests"]
        </h5>
        <span class="badge bg-info">@Localizer["Last 50"]</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="recentRequestsTable">
            <thead>
                <tr>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Virtual Model"]</th>
                    <th>@Localizer["Backend Model"]</th>
                    <th>@Localizer["API Key"]</th>
                    <th>@Localizer["Last Question"]</th>
                    <th class="text-center" style="width:40px;"></th>
                    <th>@Localizer["Duration"]</th>
                    <th>@Localizer["Error"]</th>
                    <th>@Localizer["Time"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count > 0)
                {
                    foreach (var req in Model.Items)
                    {
                        var isSuccess = req.Status == "Completed";
                        var durationStr = req.DurationMs < 1000
                            ? $"{(int)req.DurationMs}ms"
                            : $"{req.DurationMs / 1000:F1}s";
                        <tr>
                            <td data-sort="@(isSuccess ? 0 : 1)">
                                @if (isSuccess)
                                {
                                    <span class="badge bg-success">@Localizer["Completed"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"
                                          @if (!string.IsNullOrWhiteSpace(req.ErrorMessage))
                                          {
                                              <text>data-bs-toggle="tooltip" data-bs-placement="top" title="@req.ErrorMessage"</text>
                                          }>@Localizer["Failed"]</span>
                                }
                            </td>
                            <td>@req.ModelName</td>
                            <td class="text-muted small font-monospace">
                                @if (!string.IsNullOrWhiteSpace(req.BackendModelName))
                                {
                                    <i data-lucide="server" class="me-1" style="width:12px;height:12px;"></i>@req.BackendModelName
                                }
                            </td>
                            <td class="text-muted small">
                                @if (!string.IsNullOrWhiteSpace(req.ApiKeyName))
                                {
                                    <i data-lucide="key" class="me-1" style="width:12px;height:12px;"></i>@req.ApiKeyName
                                }
                                else
                                {
                                    <em>@Localizer["(anonymous)"]</em>
                                }
                            </td>
                            <td class="font-monospace text-muted small">
                                @if (!string.IsNullOrWhiteSpace(req.Question))
                                {
                                    @req.Question
                                    @if (req.Question.Length >= 30)
                                    {
                                        <text>...</text>
                                    }
                                }
                                else
                                {
                                    <em>@Localizer["(no content)"]</em>
                                }
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrWhiteSpace(req.FullQuestion) && req.FullQuestion.Length > 30)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary btn-view-message"
                                            data-full-message="@req.FullQuestion"
                                            title="@Localizer["View full message"]">
                                        <i data-lucide="maximize-2" style="width:14px;height:14px;"></i>
                                    </button>
                                }
                            </td>
                            <td data-sort="@req.DurationMs" class="text-muted small">@durationStr</td>
                            <td class="text-muted small">
                                @if (!string.IsNullOrWhiteSpace(req.ErrorMessage))
                                {
                                    var shortError = req.ErrorMessage.Length > 60 ? req.ErrorMessage[..60] + "..." : req.ErrorMessage;
                                    <span class="text-danger font-monospace" data-bs-toggle="tooltip" data-bs-placement="top" title="@req.ErrorMessage">@shortError</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td data-sort="@req.CompletedAt.Ticks" class="text-muted small"><label data-utc-time="@req.CompletedAt.ToHtmlDateTime()" class="mb-0"></label></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-3">
                            <i data-lucide="inbox" class="me-1" style="width:16px;height:16px;"></i>
                            @Localizer["No recent requests — data will appear once requests complete"]
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Full Message Modal -->
<div class="modal fade" id="fullMessageModal" tabindex="-1" aria-labelledby="fullMessageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fullMessageModalLabel">@Localizer["Full Request Message"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre class="bg-body-tertiary p-3 rounded mb-0" id="fullMessageContent" style="white-space: pre-wrap; word-break: break-word;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
            </div>
        </div>
    </div>
</div>

@if (Model.Items.Count > 0)
{
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var table = $('#recentRequestsTable').DataTable({
                "destroy": true,
                "responsive": true,
                "paging": true,
                "pageLength": 10,
                "searching": false,
                "info": false,
                "order": [[8, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": [2, 3, 4, 5, 7] }
                ],
                "drawCallback": function () {
                    [].slice.call(document.querySelectorAll('#recentRequestsTable [data-bs-toggle="tooltip"]')).map(function (tooltipTriggerEl) {
                        var existing = bootstrap.Tooltip.getInstance(tooltipTriggerEl);
                        if (existing) existing.dispose();
                        return new bootstrap.Tooltip(tooltipTriggerEl, { trigger: 'hover' });
                    });
                    lucide.createIcons();
                }
            });

            // Delegate click handler for view message buttons
            $('#recentRequestsTable').on('click', '.btn-view-message', function() {
                var fullMessage = this.getAttribute('data-full-message');
                document.getElementById('fullMessageContent').textContent = fullMessage;
                var modal = new bootstrap.Modal(document.getElementById('fullMessageModal'));
                modal.show();
            });
        });
    </script>
}
