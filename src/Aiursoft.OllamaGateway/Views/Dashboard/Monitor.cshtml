@model Aiursoft.OllamaGateway.Models.DashboardViewModels.MonitorViewModel
@using Aiursoft.OllamaGateway.Entities
@using System.Text
@using System.Text.RegularExpressions

@{
    // Build a deduplicated map of physical nodes keyed by (ProviderId, ModelName).
    // When multiple virtual models share the same physical backend we only render it once.
    var physicalNodeMap = new Dictionary<(int ProviderId, string ModelName), VirtualModelBackend>();
    foreach (var vm in Model.VirtualModels)
    {
        foreach (var backend in vm.VirtualModelBackends)
        {
            var key = (backend.ProviderId, backend.UnderlyingModelName);
            physicalNodeMap.TryAdd(key, backend);
        }
    }

    // Produce a stable, Mermaid-safe node ID for a physical backend.
    string PhysNodeId(int providerId, string modelName)
    {
        var sanitized = Regex.Replace(modelName, @"[^a-zA-Z0-9]", "_");
        return $"Phys_P{providerId}_{sanitized}";
    }

    var sb = new StringBuilder();
    sb.AppendLine("graph LR");
    sb.AppendLine("    %% Define global style classes");
    sb.AppendLine("    classDef gateway fill:#2d3748,stroke:#1a202c,stroke-width:2px,color:#fff,rx:8px,ry:8px;");
    sb.AppendLine("    classDef virtualSvc fill:#4a5568,stroke:#2d3748,stroke-width:2px,color:#fff,rx:5px,ry:5px;");
    sb.AppendLine("    classDef virtualSvcBusy fill:#b7791f,stroke:#744210,stroke-width:3px,color:#fff,rx:5px,ry:5px;");
    sb.AppendLine("    ");
    sb.AppendLine("    %% Define backend node status colors");
    sb.AppendLine("    classDef ready fill:#38a169,stroke:#276749,stroke-width:2px,color:#fff,rx:15px,ry:15px;");
    sb.AppendLine("    classDef healthy fill:#3182ce,stroke:#2b6cb0,stroke-width:2px,color:#fff,rx:15px,ry:15px;");
    sb.AppendLine("    classDef down fill:#e53e3e,stroke:#c53030,stroke-width:2px,color:#fff,rx:15px,ry:15px;");
    sb.AppendLine("    classDef banned fill:#805ad5,stroke:#553c9a,stroke-width:2px,color:#fff,rx:15px,ry:15px;");
    sb.AppendLine("    ");
    sb.AppendLine("    classDef algo fill:#edf2f7,stroke:#a0aec0,stroke-width:1px,color:#4a5568,stroke-dasharray: 5 5;");
    sb.AppendLine("    classDef client fill:#f7fafc,stroke:#cbd5e0,stroke-width:2px,color:#2d3748,rx:20px,ry:20px;");

    sb.AppendLine();
    sb.AppendLine($"    Client([\"🌐 {Localizer["External Traffic (Client)"].Value}\"]):::client");
    sb.AppendLine();
    sb.AppendLine($"    subgraph LB_Core [{Localizer["Core Load Balancer Gateway"].Value}]");
    sb.AppendLine($"        Gateway{{\"🛡️ {Localizer["Load Balancer"].Value}<br/>(Gateway)\"}}:::gateway");

    foreach (var vm in Model.VirtualModels)
    {
        var isBusy = Model.BusyModels.Contains(vm.Name);
        sb.AppendLine();
        sb.AppendLine($"        subgraph VS_{vm.Id} [{Localizer["Virtual Service"].Value} {vm.Name}]");
        var svcClass = isBusy ? "virtualSvcBusy" : "virtualSvc";
        var svcLabel = isBusy ? $"🔥 {vm.Name}<br/>({vm.Type})" : $"📦 {vm.Name}<br/>({vm.Type})";
        sb.AppendLine($"            Svc_{vm.Id}(\"{svcLabel}\"):::{svcClass}");
        var algoStr = vm.SelectionStrategy.ToString();
        sb.AppendLine($"            Algo_{vm.Id}[\"⚖️ {algoStr}\"]:::algo");
        sb.AppendLine($"            Svc_{vm.Id} --- Algo_{vm.Id}");
        sb.AppendLine("        end");
    }
    sb.AppendLine("    end");

    // Render one subgraph per provider, containing only the unique physical models for that provider.
    var byProvider = physicalNodeMap.GroupBy(kv => kv.Key.ProviderId);
    foreach (var providerGroup in byProvider)
    {
        var providerName = providerGroup.First().Value.Provider?.Name ?? $"Provider {providerGroup.Key}";
        sb.AppendLine();
        sb.AppendLine($"    subgraph PhysPool_P{providerGroup.Key} [{Localizer["Backend Pool"].Value} {providerName}]");
        foreach (var kv in providerGroup)
        {
            var backend = kv.Value;
            var nodeId = PhysNodeId(kv.Key.ProviderId, kv.Key.ModelName);
            
            var matchingBackends = Model.VirtualModels
                .SelectMany(m => m.VirtualModelBackends)
                .Where(b => b.ProviderId == kv.Key.ProviderId && b.UnderlyingModelName == kv.Key.ModelName)
                .ToList();
            var banTimes = matchingBackends.Select(b => Model.BackendBanStatuses.GetValueOrDefault(b.Id)).ToList();
            var isBanned = banTimes.Any(t => t.HasValue && t.Value > DateTime.UtcNow);

            var statusClass = isBanned ? "banned" : backend.IsReady ? "ready" : (backend.IsHealthy ? "healthy" : "down");
            var icon = isBanned ? "🚫" : backend.IsReady ? "🟢" : (backend.IsHealthy ? "🔵" : "🔴");
            var statusText = isBanned ? "Banned" : backend.IsReady ? "Ready" : (backend.IsHealthy ? "Healthy" : "Down");
            
            sb.AppendLine($"        {nodeId}[(\"{icon} {providerName}<br/>{backend.UnderlyingModelName}<br/>{statusText}\")]:::{statusClass}");
        }
        sb.AppendLine("    end");
    }

    // Handle virtual models that have no backends at all.
    foreach (var vm in Model.VirtualModels.Where(v => !v.VirtualModelBackends.Any()))
    {
        sb.AppendLine();
        sb.AppendLine($"    subgraph Pool_Empty_{vm.Id} [{Localizer["Backend Pool"].Value} {vm.Name}]");
        sb.AppendLine($"        Empty_{vm.Id}[\"{Localizer["No Backend Nodes"].Value}\"]:::down");
        sb.AppendLine("    end");
    }

    sb.AppendLine();
    sb.AppendLine($"    Client ===|\"{Localizer["Entry Traffic"].Value}\"| Gateway");

    foreach (var vm in Model.VirtualModels)
    {
        sb.AppendLine($"    Gateway == \"{Localizer["Route"].Value}: {vm.Name}\" ==> Svc_{vm.Id}");

        foreach (var backend in vm.VirtualModelBackends)
        {
            var nodeId = PhysNodeId(backend.ProviderId, backend.UnderlyingModelName);
            var actionText = (backend.Enabled && backend.IsHealthy) ? Localizer["Dispatch Traffic"].Value : Localizer["Block Node"].Value;
            sb.AppendLine($"    Algo_{vm.Id} -. \"{actionText}\" .-> {nodeId}");
        }
    }

    var mermaidCode = sb.ToString();
}

<div class="container-fluid p-0">
    <div class="row mb-2 mb-xl-3">
        <div class="col-auto d-none d-sm-block">
            <h3>@Model.PageTitle</h3>
        </div>
        <div class="col-auto ms-auto text-end mt-n1">
            <a href="javascript:location.reload()" class="btn btn-primary shadow-sm ms-1">
                <i class="align-middle" data-lucide="refresh-cw"></i>
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12 d-flex">
            <div class="card flex-fill w-100">
                <div class="card-body">
                    <pre class="mermaid" style="display: flex; justify-content: center; overflow: auto; min-height: 500px;">
@mermaidCode
                    </pre>
                </div>
            </div>
        </div>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script type="module">
        import mermaid from '/node_modules/mermaid/dist/mermaid.esm.mjs';
        mermaid.initialize({ startOnLoad: true, theme: 'default' });
    </script>
}
