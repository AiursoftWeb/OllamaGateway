@model Aiursoft.OllamaGateway.Models.ApiKeysViewModels.EditViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Edit API Key"]</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Key Details"]</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">@Localizer["Friendly Name"]</label>
                            <input asp-for="Name" class="form-control" placeholder="@Localizer["e.g. My Laptop, Development"]" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                            <div class="form-text">@Localizer["A name to help you identify where this key is used."]</div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ExpirationTime" class="form-label">@Localizer["Expiration Time"]</label>
                            <input asp-for="ExpirationTime" class="form-control" type="datetime-local" />
                            <span asp-validation-for="ExpirationTime" class="text-danger"></span>
                        </div>
                        <div class="mb-3 form-check form-switch">
                            <input asp-for="RateLimitEnabled" class="form-check-input" type="checkbox">
                            <label asp-for="RateLimitEnabled" class="form-check-label">@Localizer["Enable Rate Limit"]</label>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MaxRequests" class="form-label">@Localizer["Max Requests"]</label>
                            <input asp-for="MaxRequests" class="form-control" type="number" min="1" />
                            <span asp-validation-for="MaxRequests" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TimeWindowSeconds" class="form-label">@Localizer["Time Window (Seconds)"]</label>
                            <input asp-for="TimeWindowSeconds" class="form-control" type="number" min="1" />
                            <span asp-validation-for="TimeWindowSeconds" class="text-danger"></span>
                        </div>
                        <div class="mb-3 form-check form-switch">
                            <input asp-for="RateLimitHang" class="form-check-input" type="checkbox">
                            <label asp-for="RateLimitHang" class="form-check-label">@Localizer["Wait if rate limited (Hang)"]</label>
                            <div class="form-text">@Localizer["If enabled, requests will wait instead of returning 429."]</div>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">@Localizer["Save Changes"]</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
