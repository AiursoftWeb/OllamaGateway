@model Aiursoft.OllamaGateway.Models.ApiKeysViewModels.UsageViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["API Key Usage Guide"]</h1>
        </div>
        <div class="col-auto ms-auto text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="align-middle me-1" data-lucide="arrow-left"></i>
                @Localizer["Back to List"]
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Using API Key"]: <strong>@Model.ApiKeyName</strong></h5>
        </div>
        <div class="card-body">
            <p>@Localizer["You can use this API key to access the Ollama Gateway API. The base URL is:"] <code>@Model.BaseUrl</code></p>

            <h4 class="mt-4">@Localizer["1. Text Completion"]</h4>
            <p>@Localizer["To simply complete a given text, use the following curl command:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>curl @(Model.BaseUrl)/api/generate \
  -H "Authorization: Bearer @Model.ApiKey" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "@Model.DefaultChatModel",
    "prompt": "Why is the sky blue? Because the atmosphere scatters sunlight in a way th",
    "stream": false,
    "raw": true
  }'</code></pre>
            </div>
			<div class="alert alert-warning mt-3" role="alert">
				<i data-lucide="alert-triangle" class="me-2"></i>
				@Localizer["Only available for Ollama underlying models. This feature is exclusive to Ollama. OpenAI and VLLM underlying models do not support this feature."]
			</div>

            <h4 class="mt-4">@Localizer["2. Chat Completion (Ollama Format)"]</h4>
            <p>@Localizer["To ask a question, use the following curl command:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>curl @(Model.BaseUrl)/api/chat \
  -H "Authorization: Bearer @Model.ApiKey" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "@Model.DefaultChatModel",
    "messages": [
      {
        "role": "user",
        "content": "why is the sky blue?"
      }
    ],
    "stream": false
  }'</code></pre>
            </div>

            <h4 class="mt-4">@Localizer["3. Chat Completion (OpenAI Format)"]</h4>
            <p>@Localizer["To ask a question in OpenAI format, use the following curl command:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>curl @(Model.BaseUrl)/v1/chat/completions \
  -H "Authorization: Bearer @Model.ApiKey" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "@Model.DefaultChatModel",
    "messages": [
      {
        "role": "user",
        "content": "why is the sky blue?"
      }
    ],
    "stream": false
  }'</code></pre>
            </div>

            <h4 class="mt-4">@Localizer["4. Embedding"]</h4>
            <p>@Localizer["To generate embeddings for a text, use the following curl command:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>curl @(Model.BaseUrl)/api/embed \
  -H "Authorization: Bearer @Model.ApiKey" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "@Model.DefaultEmbeddingModel",
    "input": "why is the sky blue?"
  }'</code></pre>
            </div>

            <h4 class="mt-4">@Localizer["5. Opencode Usage"]</h4>
            <p>@Localizer["After creating an API Key, you can edit your Opencode configuration file at"] <code>~/.config/opencode/opencode.json</code> @Localizer["to add a new provider:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama-gateway": {
      "name": "Ollama Gateway",
      "npm": "@@ai-sdk/openai-compatible",
      "models": {
        "@Model.DefaultChatModel": {
          "name": "@Model.DefaultChatModel"
        }
      },
      "options": {
        "baseURL": "@(Model.BaseUrl)/v1",
        "headers": {
          "Authorization": "Bearer @Model.ApiKey"
        }
      }
    }
  },
  "disabled_providers": []
}</code></pre>
            </div>
            <p>@Localizer["Then you can enjoy using OllamaGateway in Opencode."] <a href="https://opencode.ai/" target="_blank">@Localizer["Learn more about Opencode."]</a></p>

            <h4 class="mt-4">@Localizer["6. Qwen Code Usage"]</h4>
            <p>@Localizer["After creating an API Key, you can edit your Qwen Code configuration file at"] <code>~/.qwen/settings.json</code> @Localizer["to add a new provider:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>{
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "model": {
    "name": "@Model.DefaultChatModel"
  },
  "env": {
    "OLLAMA_GATEWAY_API_KEY": "@Model.ApiKey"
  },
  "modelProviders": {
    "openai": [
      {
        "id": "@Model.DefaultChatModel",
        "name": "Ollama Gateway (@Model.ApiKeyName)",
        "envKey": "OLLAMA_GATEWAY_API_KEY",
        "baseUrl": "@(Model.BaseUrl)/v1"
      }
    ]
  }
}</code></pre>
            </div>
            <p>@Localizer["Then you can use Qwen Code to access the Ollama Gateway."] <a href="https://github.com/QwenLM/qwen-code" target="_blank">@Localizer["Learn more about Qwen Code."]</a></p>

            <h4 class="mt-4">@Localizer["7. Anthropic Messages API"]</h4>
            <p>@Localizer["To ask a question in Anthropic Messages format, use the following curl command:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>curl @(Model.BaseUrl)/v1/messages \
  -H "x-api-key: @Model.ApiKey" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "@Model.DefaultChatModel",
    "max_tokens": 1024,
    "messages": [
      {"role": "user", "content": "Hello!"}
    ]
  }'</code></pre>
            </div>

            <h4 class="mt-4">@Localizer["8. Claude Code & CC Switch (Recommended)"]</h4>
            <p>@Localizer["Claude Code is a powerful CLI agent from Anthropic. We recommend using 'CC Switch' (an All-in-One manager) to manage your configurations easily."] <a href="https://github.com/farion1231/cc-switch" target="_blank">@Localizer["Learn more about CC Switch."]</a></p>

            <h5 class="mt-3">@Localizer["Option A: Using CC Switch (GUI)"]</h5>
            <ol>
                <li>@Localizer["Download and install"] <a href="https://github.com/farion1231/cc-switch/releases" target="_blank">CC Switch</a>.</li>
                <li>@Localizer["Click 'Add Provider' and select 'Claude Code' as the target tool."]</li>
                <li>@Localizer["Fill in the following configuration:"]
                    <ul>
                        <li><strong>@Localizer["Provider Name"]:</strong> <code>Ollama Gateway</code></li>
                        <li><strong>@Localizer["Base URL"]:</strong> <code>@Model.BaseUrl</code></li>
                        <li><strong>@Localizer["API Key"]:</strong> <code>@Model.ApiKey</code></li>
                        <li><strong>@Localizer["Model Name"]:</strong> <code>@Model.DefaultChatModel</code></li>
                    </ul>
                </li>
                <li>@Localizer["Click 'Enable' in the system tray or main interface. Now your 'claude' command will use this gateway."]</li>
            </ol>

            <h5 class="mt-3">@Localizer["Option B: Manual Configuration (Environment Variables)"]</h5>
            <p>@Localizer["Claude Code natively reads standard Anthropic environment variables. You can configure it manually by exporting these variables in your terminal:"]</p>
            <div class="position-relative">
                <pre class="bg-dark text-light p-3 rounded"><code>export ANTHROPIC_API_KEY="@Model.ApiKey"
export ANTHROPIC_BASE_URL="@Model.BaseUrl"

# Start Claude Code and specify your model
claude --model @Model.DefaultChatModel</code></pre>
            </div>
            <p>@Localizer["To make this permanent, you can add the export commands to your shell profile (e.g., ~/.bashrc or ~/.zshrc)."]</p>

            <p class="text-muted mt-4">
                <i data-lucide="info" class="me-1"></i>
                @Localizer["Note: Replace '{0}' or '{1}' with other available models if needed.", Model.DefaultChatModel, Model.DefaultEmbeddingModel]
            </p>
        </div>
    </div>
</div>
