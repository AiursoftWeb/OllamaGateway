@model Aiursoft.OllamaGateway.Models.ApiKeysViewModels.IndexViewModel
@using Aiursoft.WebTools

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Your API Keys"]</h1>
        </div>
        <div class="col-auto ms-auto text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="align-middle me-1" data-lucide="plus"></i>
                @Localizer["Create New Key"]
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.NewKey))
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <div class="alert-message">
                <h4 class="alert-heading">@Localizer["API Key Created!"]</h4>
                <p>@Localizer["Please copy your new API key now. You won't be able to see it again!"]</p>
                <hr>
                <p class="mb-0">
                    <code>@Model.NewKey</code>
                </p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Manage your API keys for accessing Ollama Gateway"]</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Key"]</th>
                        <th>@Localizer["Created At"]</th>
                        <th>@Localizer["Last Used"]</th>
                        <th>@Localizer["Total Calls"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ApiKeys.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                @Localizer["You don't have any API keys yet."]
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var key in Model.ApiKeys)
                        {
                            <tr>
                                <td>@key.Name</td>
                                <td>
                                    <code>@key.Key[..4]...</code>
                                </td>
                                <td><label data-utc-time="@key.CreatedAt.ToHtmlDateTime()" class="mb-0"></label></td>
                                <td>
                                    @if (Model.LastUsedTimes[key.Id].HasValue)
                                    {
                                        <label data-utc-time="@Model.LastUsedTimes[key.Id]!.Value.ToHtmlDateTime()" class="mb-0"></label>
                                    }
                                    else
                                    {
                                        @Localizer["Never"]
                                    }
                                </td>
                                <td>@Model.TotalCalls[key.Id]</td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Usage" asp-route-id="@key.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="align-middle me-1" data-lucide="terminal"></i>
                                            @Localizer["Use"]
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@key.Id" class="btn btn-sm btn-outline-secondary">
                                            <i class="align-middle me-1" data-lucide="edit"></i>
                                            @Localizer["Edit"]
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@key.Id" method="post" onsubmit="return confirm('@Localizer["Are you sure you want to delete this API key?"]');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="align-middle" data-lucide="trash-2"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
