@model Aiursoft.OllamaGateway.Models.HomeViewModels.SelfHostViewModel

<div class="container-fluid p-0">
    <div class="row mb-2 mb-xl-3">
        <div class="col-auto d-none d-sm-block">
            <h3><strong>@Localizer["Self Host"]</strong> @Localizer["OllamaGateway"]</h3>
        </div>

        <div class="col-auto ms-auto text-end mt-n1">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mt-1 mb-0">
                    <li class="breadcrumb-item"><a href="#">Aiursoft</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">OllamaGateway</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Localizer["Self Host"]</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h5 class="card-title">@Localizer["About OllamaGateway"]</h5>
                            <p class="text-muted">
                                @Localizer["OllamaGateway is built for private AI infrastructure. If you want API authentication, request auditing, virtual models, and team-friendly controls on top of Ollama, local deployment is the recommended way to run it."]
                            </p>
                            <div class="mb-3">
                                <a href="https://github.com/aiursoftweb/OllamaGateway/blob/master/LICENSE" target="_blank" class="d-inline-block me-1 mb-1">
                                    <img src="https://img.shields.io/badge/license-MIT-blue.svg" alt="MIT licensed">
                                </a>
                                <a href="https://hub.docker.com/r/aiursoft/ollamagateway" target="_blank" class="d-inline-block me-1 mb-1">
                                    <img src="https://img.shields.io/docker/pulls/aiursoft/ollamagateway.svg" alt="Docker Pulls">
                                </a>
                                <a href="https://ollama.aiursoft.com" target="_blank" class="d-inline-block me-1 mb-1">
                                    <img src="https://img.shields.io/website?url=https%3A%2F%2Follama.aiursoft.com" alt="Website">
                                </a>
                            </div>
                        </div>
                        <div class="col-md-4 text-md-end align-self-center">
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
                                <i class="align-middle me-1" data-lucide="layout-dashboard"></i> @Localizer["Dashboard"]
                            </a>
                            <a href="https://github.com/aiursoftweb/OllamaGateway" target="_blank" class="btn btn-outline-primary">
                                <i class="align-middle me-1" data-lucide="github"></i> @Localizer["GitHub"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-xl-8">
            <div class="card border-primary flex-fill w-100">
                <div class="card-header">
                    <div class="card-actions float-end">
                        <span class="badge bg-primary">@Localizer["Recommended"]</span>
                    </div>
                    <h5 class="card-title mb-0">
                        <i class="align-middle me-2 text-primary" data-lucide="container"></i>
                        @Localizer["Run in Docker"]
                    </h5>
                </div>
                <div class="card-body">
                    <p>@Localizer["First, install Docker. Then run the following commands in a Linux shell:"]</p>

                    <div class="bg-light p-3 rounded border mb-3">
                        <code class="text-dark user-select-all">
                            image=aiursoft/ollamagateway<br>
                            appName=ollamagateway<br>
                            sudo docker pull $image<br>
                            sudo docker run -d --name $appName --restart unless-stopped -p 5000:5000 -v /var/www/$appName:/data $image
                        </code>
                    </div>

                    <p class="text-muted small">@Localizer["That will start a web server at http://localhost:5000 and you can test the app."]</p>
                    <p class="text-muted small">@Localizer["The default username is:"] <code>admin@default.com</code>, @Localizer["and the default password is:"] <code>admin123</code>.</p>

                    <h6 class="mt-4">@Localizer["Container Context"]</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>@Localizer["Property"]</th>
                                    <th>@Localizer["Value"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>@Localizer["Image"]</td>
                                    <td><code>aiursoft/ollamagateway</code></td>
                                </tr>
                                <tr>
                                    <td>@Localizer["Ports"]</td>
                                    <td><code>5000</code></td>
                                </tr>
                                <tr>
                                    <td>@Localizer["Binary path"]</td>
                                    <td><code>/app</code></td>
                                </tr>
                                <tr>
                                    <td>@Localizer["Data path"]</td>
                                    <td><code>/data</code></td>
                                </tr>
                                <tr>
                                    <td>@Localizer["Config path"]</td>
                                    <td><code>/data/appsettings.json</code></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card flex-fill w-100">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="align-middle me-2" data-lucide="terminal"></i>
                        @Localizer["Run in Ubuntu"]
                    </h5>
                </div>
                <div class="card-body">
                    <p class="card-text">@Localizer["The following script will install/update this app on your Ubuntu server. Supports Ubuntu 25.04."]</p>
                    <div class="bg-light p-2 rounded border mb-3">
                        <code class="text-dark small user-select-all">curl -sL https://github.com/aiursoftweb/ollamaGateway/raw/master/install.sh | sudo bash</code>
                    </div>
                    <p class="card-text"><small class="text-muted">@Localizer["Or with a custom port:"]</small></p>
                    <div class="bg-light p-2 rounded border">
                        <code class="text-dark small user-select-all">curl -sL https://github.com/aiursoftweb/ollamaGateway/raw/master/install.sh | sudo bash -s 8080</code>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-secondary">Systemd</span>
                        <span class="badge bg-secondary">/opt/apps</span>
                    </div>
                </div>
            </div>

            <div class="card flex-fill w-100 mt-3">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="align-middle me-2 text-info" data-lucide="activity"></i>
                        @Localizer["Why local deployment"]
                    </h5>
                </div>
                <div class="card-body">
                    <p class="card-text">@Localizer["Keep prompts, API keys, usage logs, and model routing inside your own infrastructure boundary."]</p>
                    <p class="card-text">@Localizer["This is especially useful when serving a team, internal tools, or autonomous agents over an OpenAI-compatible endpoint."]</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="align-middle me-2" data-lucide="code-2"></i>
                        @Localizer["Development & Manual Run"]
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>@Localizer["Prerequisites"]</h6>
                            <ul>
                                <li><a href="http://dot.net/">.NET 10 SDK</a></li>
                                <li><a href="https://nodejs.org/">Node.js</a></li>
                            </ul>
                            <h6>@Localizer["Run Manually"]</h6>
                            <ol>
                                <li>@Localizer["Execute `npm install` at `wwwroot` folder to install the dependencies."]</li>
                                <li>@Localizer["Execute `dotnet run` to run the app."]</li>
                                <li>@Localizer["Visit http://localhost:5000."]</li>
                            </ol>
                        </div>
                        <div class="col-md-6">
                            <h6>@Localizer["Run in Visual Studio"]</h6>
                            <ol>
                                <li>@Localizer["Open the `.sln` file in the project path."]</li>
                                <li>@Localizer["Press `F5` to run the app."]</li>
                            </ol>
                            <div class="alert alert-info" role="alert">
                                <div class="alert-icon">
                                    <i class="align-middle" data-lucide="info"></i>
                                </div>
                                <div class="alert-message">
                                    @Localizer["If you deploy for real use, change the default password immediately and put the site behind your normal TLS and network controls."]
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
