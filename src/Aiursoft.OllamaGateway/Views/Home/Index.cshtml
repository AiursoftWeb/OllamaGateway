@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row align-items-center h-100">
            <div class="col-lg-5 mx-auto">
                <span class="badge badge-subtle-primary p-1">@Localizer["Open Source"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["Private AI"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["MIT Licence"]</span>
                <h1 id="main-slogan" class="my-4 text-white" style="font-size: 3rem;">
                    @Localizer["Supercharge Your Native"] <span class='text-primary'>@Localizer["Ollama."]</span>
                </h1>
                <p class="text-lg text-white-50">@Localizer["Ollama Gateway: Supercharge your native Ollama with enterprise-grade API authentication, request auditing, and virtual model management—your secure, private AI gateway."]</p>
                <div class="my-4">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="grid"></i> @Localizer["Go to dashboard"]
                    </a>
                    <a href="https://github.com/aiursoftweb/OllamaGateway" target="_blank" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="github"></i> @Localizer["View on GitHub"]
                    </a>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex mx-auto text-center">
                <div class="landing-intro-screenshot shadow-lg">
                    <img src="~/images/screenshot.png" alt="OllamaGateway Main screenshot" class="img-fluid rounded" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Enterprise Ready"]</span>
            <h2 class="h1">@Localizer["Security and Auditing by Design."]</h2>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="shield-check"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Bearer Token Auth"]</h4>
                        <p class="fs-lg">@Localizer["Create multiple API keys for different users and applications, each with its own fine-grained permissions."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="database"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Clickhouse Auditing"]</h4>
                        <p class="fs-lg">@Localizer["Detailed auditing for every request and response, stored in high-performance Clickhouse storage for compliance."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="user-cog"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Team Management"]</h4>
                        <p class="fs-lg">@Localizer["A built-in Role-Based Access Control (RBAC) system for managing your team's access to AI models."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="zap"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Model Keep-alive"]</h4>
                        <p class="fs-lg">@Localizer["Periodically pings underlying models to ensure they stay loaded in memory for instant response times."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="cpu"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Default Model Support"]</h4>
                        <p class="fs-lg">@Localizer["Automatically redirect requests to a default virtual model if no model is specified in the API call."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="refresh-cw"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Native Passthrough"]</h4>
                        <p class="fs-lg">@Localizer["Seamless support for native Ollama features including MCP tools, embedding, images, and stream mode."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="immersive-section position-relative w-100 overflow-hidden d-flex align-items-center">
    
    <div class="immersive-bg">
        <div class="bg-image-wrapper">
             <img src="~/images/template_running_in_docker.webp" alt="OllamaGateway in Docker" class="img-fluid object-fit-cover w-100 h-100">
        </div>
        <div class="bg-overlay"></div>
    </div>

    <div class="container position-relative z-2 py-5">
        <div class="row">
            <div class="col-lg-6 offset-lg-6 col-md-12">
                
                <div class="mb-5 text-start ps-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-info me-2"><i class="fas fa-server"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Smart Proxy"]</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        <span class="text-primary">@Localizer["Intelligent"]</span><br>
                        @Localizer["Virtual Models"]
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        @Localizer["Create multiple aliases for your models with custom system prompts and parameter overrides."]
                    </p>
                </div>

                <div class="row g-3 ps-lg-4">
                    
                    @* Card 1: Chat Models *@
                    <div class="col-md-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-success-subtle text-success rounded-3 me-3 mb-3">
                                    <i class="fas fa-comments fa-lg"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Chat Models"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm"> @Localizer["Create virtual chat models with persistent system prompts."]</p>
                            </div>
                        </div>
                    </div>

                    @* Card 2: Embedding Models *@
                    <div class="col-md-6">
                         <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-info-subtle text-info rounded-3 me-3 mb-3">
                                    <i class="fas fa-project-diagram fa-lg"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Embedding Models"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm"> @Localizer["Dedicated management for embedding models for RAG applications."]</p>
                            </div>
                        </div>
                    </div>

                    @* Card 3: Full Control *@
                    <div class="col-12">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4 d-flex align-items-center">
                                <div class="icon-box-sm bg-white-10 text-white rounded-3 me-3">
                                    <i class="fas fa-sliders-h"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-white mb-1 fs-6"> @Localizer["Parameter Overrides"]</h5>
                                    <p class="text-gray-400 mb-0">@Localizer["Override temperature, top_k, and other Ollama options per virtual model."]</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift text-center py-2">
                            <div class="card-body p-2">
                                <i class="fas fa-link text-warning mb-2 fs-5"></i>
                                <div class="text-gray-300 fw-bold" style="font-size: 0.75rem">@Localizer["Smart Mapping"]</div>
                                <div class="text-gray-500">@Localizer["Alias -> Real"]</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift text-center py-2">
                            <div class="card-body p-2">
                                <i class="fas fa-check-double text-primary mb-2 fs-5"></i>
                                <div class="text-gray-300 fw-bold" style="font-size: 0.75rem">@Localizer["Validation"]</div>
                                <div class="text-gray-500">@Localizer["Auto Sync"]</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="mb-4 text-start">
                    <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Agent & Ecosystem Ready"]</span>
                    <h2 class="h1">@Localizer["Perfect for Agent Deployment"]</h2>
                </div>
                <p class="fs-lg text-muted">@Localizer["OllamaGateway has been officially tested and is fully compatible with popular ecosystem tools including Open-WebUI, Opencode, and Roocode. Its robust API translation makes it the ideal choice for deploying autonomous AI agents."]</p>
            </div>
            <div class="col-lg-6">
                <div class="card bg-dark text-white border-0 shadow">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i data-lucide="cpu" class="text-primary me-2"></i>
                            <h5 class="mb-0 fw-bold">@Localizer["Recommended Models"]</h5>
                        </div>
                        <ul class="list-unstyled mb-0 fs-lg">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> <code class="text-white bg-dark-glass px-2 py-1 rounded">qwen3.5:27b-q8_0</code></li>
                            <li><i class="fas fa-check text-success me-2"></i> <code class="text-white bg-dark-glass px-2 py-1 rounded">qwen3.5:35b-a3b-q4_K_M</code></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-light">
    <div class="container">
        <div class="mb-5 text-center px-4">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Native vs. Gateway"]</span>
            <h2 class="h1">@Localizer["Why choose OllamaGateway?"]</h2>
            <div class="row justify-content-center">
                <div class="col-lg-10 col-xl-8">
                    <p class="text-muted fs-lg">
                        @Localizer["Native Ollama is great for personal use, but it lacks the enterprise features required for team collaboration and production deployment. OllamaGateway fills those gaps without changing your workflow."]
                    </p>
                </div>
            </div>
        </div>
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover table-bordered bg-white mb-0 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-start">@Localizer["Feature Comparison"]</th>
                        <th>@Localizer["Native Ollama"]</th>
                        <th>@Localizer["OllamaGateway"]</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Model Hosting & Inference"]</td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Multimodal"]</td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["MCP"]</td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Function call"]</td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Streaming"]</td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["OpenAI API Translation"]</td>
                        <td>
                            <i class="fas fa-exclamation-triangle text-warning" data-bs-toggle="tooltip" title="@Localizer["Partially supported. Lacks advanced system prompt mapping, parameter overriding, and role translation."]"></i>
                        </td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["API Authentication (Bearer)"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Multiple API Keys Management"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Request & Response Auditing"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Virtual Model Overrides"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Multi-backend Support"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Load Balancing"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Tiered Fallback"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Default Model Support"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Model Keep-alive (Ping)"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Admin Management GUI"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="text-start fw-medium">@Localizer["Chat/Embedding Segregation"]</td>
                        <td><i class="fas fa-times-circle text-danger"></i></td>
                        <td><i class="fas fa-check-circle text-success"></i></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container text-center">
        <div class="row">
            <div class="col-12 col-md-10 col-lg-9 col-xl-8 mx-auto">
                <h2 class="h1 mb-3">
                    @Localizer["Ready to secure your AI gateway?"]
                </h2>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-pill btn-lg mt-n1">
                    <i class="fa-solid fa-rocket"></i>
                    <span class="ms-1">@Localizer["Go to Dashboard"]</span>
                </a>
                <a href="https://github.com/aiursoftweb/OllamaGateway" class="btn btn-dark btn-pill btn-lg mt-n1" target="_blank">
                    <i class="fa-brands fa-github"></i>
                    <span class="ms-1">@Localizer["View on GitHub"]</span>
                </a>
            </div>
        </div>
    </div>
</section>

<vc:marketing-footer></vc:marketing-footer>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        window.addEventListener('load', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}
